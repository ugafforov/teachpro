rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function requestOwnedByCurrentUser() {
      return isAuthenticated() && request.resource.data.get('teacher_id', '') == request.auth.uid;
    }

    function resourceOwnedByCurrentUser() {
      return isAuthenticated() && resource.data.get('teacher_id', '') == request.auth.uid;
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated() && (request.auth.uid == teacherId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == teacherId;
      allow update: if isAuthenticated() && (request.auth.uid == teacherId || isAdmin());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /groups/{groupId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /attendance_records/{recordId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /group_notes/{noteId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /reward_penalty_history/{historyId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /exams/{examId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /exam_results/{resultId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /exam_types/{typeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /archived_students/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /archived_groups/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /archived_exams/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /deleted_students/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /deleted_groups/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /deleted_exams/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /deleted_attendance_records/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /deleted_reward_penalty_history/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /deleted_exam_results/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /deleted_student_scores/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /audit_logs/{logId} {
      allow create: if isAdmin() || requestOwnedByCurrentUser();
      allow read, update, delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    match /ai_analysis_runs/{runId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.get('createdBy', '') == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.get('createdBy', '') == request.auth.uid;
      allow update, delete: if isAuthenticated() && (isAdmin() || resource.data.get('createdBy', '') == request.auth.uid);
    }

    match /ai_analysis_cache/{cacheId} {
      allow read, write: if false;
    }

    match /ai_analysis_feedback/{feedbackId} {
      allow create: if isAuthenticated() && request.resource.data.get('createdBy', '') == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && (isAdmin() || resource.data.get('createdBy', '') == request.auth.uid);
    }
  }
}
