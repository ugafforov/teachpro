rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function requestOwnedByCurrentUser() {
      return isAuthenticated() &&
             request.resource.data.teacher_id is string &&
             request.resource.data.teacher_id.size() > 0 &&
             request.resource.data.teacher_id == request.auth.uid;
    }

    function resourceOwnedByCurrentUser() {
      return isAuthenticated() &&
             resource.data.teacher_id is string &&
             resource.data.teacher_id.size() > 0 &&
             resource.data.teacher_id == request.auth.uid;
    }

    // Rate limiting helper
    function isWithinRateLimit(path, max_operations, window_ms) {
      let operations = firestore.query(path)
        .where('created_at', '>', request.time - duration.value(window_ms, 'ms'))
        .where('createdBy', '==', request.auth.uid)
        .count().read;
      return operations < max_operations;
    }

    // Apply rate limiting to critical write operations
    // Limit to 100 writes per minute per user for most operations
    function isWithinWriteLimit() {
      return isWithinRateLimit(
        /databases/$(database)/documents/ai_analysis_runs,
        100,
        60000
      );
    }

    // Specific rate limit for AI analysis operations
    function isWithinAIAnalysisLimit() {
      return isWithinRateLimit(
        /databases/$(database)/documents/ai_analysis_runs,
        20,
        60000
      );
    }

    // Data validation helpers
    function hasValidTeacherId() {
      return request.resource.data.teacher_id is string && 
             request.resource.data.teacher_id.size() > 0;
    }

    function hasValidTimestamp() {
      return !request.resource.data.has('created_at') ||
             request.resource.data.created_at is timestamp;
    }

    function isValidDate(dateStr) {
      return dateStr is string && dateStr.size() == 10;
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated() && (request.auth.uid == teacherId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == teacherId && 
                       hasValidTimestamp();
      allow update: if isAuthenticated() && (request.auth.uid == teacherId || isAdmin());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Students collection (public read for rankings, restricted write)
    match /students/{studentId} {
      allow read: if true; // Public read for rankings
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      allow update: if isAuthenticated() && (isAdmin() || resourceOwnedByCurrentUser());
      allow delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    // Groups collection (public read for rankings)
    match /groups/{groupId} {
      allow read: if true; // Public read for rankings
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      allow update: if isAuthenticated() && (isAdmin() || resourceOwnedByCurrentUser());
      allow delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    // Attendance records collection (public read for rankings)
    match /attendance_records/{recordId} {
      allow read: if true; // Public read for rankings
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      // Update: allow if admin, OR owner of existing doc, OR creating new doc with valid teacher_id
      allow update: if isAuthenticated() && (isAdmin() ||
                       (resource.data.keys().hasAny(['teacher_id']) && resource.data.teacher_id == request.auth.uid) ||
                       (request.resource.data.keys().hasAny(['teacher_id']) && request.resource.data.teacher_id == request.auth.uid));
      allow delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    // Group notes
    match /group_notes/{noteId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      allow update: if isAuthenticated() && (isAdmin() || resourceOwnedByCurrentUser());
      allow delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    // Reward and penalty history (public read for rankings)
    match /reward_penalty_history/{historyId} {
      allow read: if true; // Public read for rankings
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      allow update: if isAuthenticated() && (isAdmin() || resourceOwnedByCurrentUser());
      allow delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    // Exams collection
    match /exams/{examId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      allow update: if isAuthenticated() && (isAdmin() || resourceOwnedByCurrentUser());
      allow delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    // Exam results collection (public read for rankings)
    match /exam_results/{resultId} {
      allow read: if true; // Public read for rankings
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      allow update: if isAuthenticated() && (isAdmin() || resourceOwnedByCurrentUser());
      allow delete: if isAdmin() || resourceOwnedByCurrentUser();
    }

    // Exam types (read-only for authenticated users, write for admins)
    match /exam_types/{typeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Archived collections with same access rules as originals
    match /archived_students/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      allow update: if isAdmin() || resourceOwnedByCurrentUser();
      allow delete: if isAdmin();
    }

    match /archived_groups/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      allow update: if isAdmin() || resourceOwnedByCurrentUser();
      allow delete: if isAdmin();
    }

    match /archived_exams/{docId} {
      allow read: if isAdmin() || resourceOwnedByCurrentUser();
      allow create: if isAuthenticated() && (isAdmin() || requestOwnedByCurrentUser()) &&
                       hasValidTeacherId() && hasValidTimestamp();
      allow update: if isAdmin() || resourceOwnedByCurrentUser();
      allow delete: if isAdmin();
    }

    // Soft deleted collections (append-only logs)
    match /deleted_students/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /deleted_groups/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /deleted_exams/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /deleted_attendance_records/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /deleted_reward_penalty_history/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /deleted_exam_results/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /deleted_student_scores/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Audit logs (append-only)
    match /audit_logs/{logId} {
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (request.resource.data.teacher_id is string &&
         request.resource.data.teacher_id.size() > 0 &&
         request.resource.data.teacher_id == request.auth.uid)
      );
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // AI analysis runs and feedback
    match /ai_analysis_runs/{runId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.createdBy is string &&
         resource.data.createdBy.size() > 0 &&
         resource.data.createdBy == request.auth.uid)
      );
      allow create: if isAuthenticated() && 
                       request.resource.data.createdBy is string &&
                       request.resource.data.createdBy.size() > 0 &&
                       request.resource.data.createdBy == request.auth.uid &&
                       hasValidTimestamp() &&
                       isWithinAIAnalysisLimit();
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.createdBy is string &&
         resource.data.createdBy.size() > 0 &&
         resource.data.createdBy == request.auth.uid)
      );
      allow delete: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.createdBy is string &&
         resource.data.createdBy.size() > 0 &&
         resource.data.createdBy == request.auth.uid)
      );
    }

    // AI analysis cache (write-protected in production)
    match /ai_analysis_cache/{cacheId} {
      allow read, write: if false;
    }

    // AI analysis feedback
    match /ai_analysis_feedback/{feedbackId} {
      allow create: if isAuthenticated() && 
                       request.resource.data.createdBy is string &&
                       request.resource.data.createdBy.size() > 0 &&
                       request.resource.data.createdBy == request.auth.uid &&
                       hasValidTimestamp() &&
                       isWithinAIAnalysisLimit();
      allow read: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.createdBy is string &&
         resource.data.createdBy.size() > 0 &&
         resource.data.createdBy == request.auth.uid)
      );
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.createdBy is string &&
         resource.data.createdBy.size() > 0 &&
         resource.data.createdBy == request.auth.uid)
      );
      allow delete: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.createdBy is string &&
         resource.data.createdBy.size() > 0 &&
         resource.data.createdBy == request.auth.uid)
      );
    }

    // Public student scores (read-only for everyone, write only for admins)
    match /public_student_scores/{scoreId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
